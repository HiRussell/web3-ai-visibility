# Single OpenRouter key drives all configured models (D-010).
# Get one at https://openrouter.ai/keys — pre-pay $5–10 to start.
OPENROUTER_API_KEY=

# Override defaults if needed
DEFILLAMA_API_BASE=https://api.llama.fi
